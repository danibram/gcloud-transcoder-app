{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcoder App",
  "version": "1.0.0",
  "identifier": "com.dbr.gcloud-transcoder-app",
  "build": {
    "beforeDevCommand": "node scripts/run-ui-command.cjs dev",
    "beforeBuildCommand": "node scripts/run-ui-command.cjs build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Transcoder App",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
