{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcoder App",
  "version": "1.0.0",
  "identifier": "com.dbr.gcloud-transcoder-app",
  "build": {
    "beforeDevCommand": "sh -c 'if [ -f ui/package.json ]; then cd ui && npm run dev; else cd ../ui && npm run dev; fi'",
    "beforeBuildCommand": "sh -c 'if [ -f ui/package.json ]; then cd ui && npm run build; else cd ../ui && npm run build; fi'",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Transcoder App",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ]
  }
}
